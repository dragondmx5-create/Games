DATABASE_URL=postgresql://undral:undral_dev@localhost:5432/undral
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_TTL=15m
JWT_ISSUER=undral-api
JWT_AUDIENCE=undral-game
JWT_REFRESH_TTL_DAYS=30
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
# Comma-separated origins. Include the installed Capacitor app origin in production.
CORS_ORIGIN=http://localhost:5173,https://app.undral.game,capacitor://app.undral.game
PORT=8787
NODE_ENV=development
# false, true, hop count (for example 1), or an Express trust-proxy subnet
TRUST_PROXY=false
# shared secret for the internal service-to-service API (/api/internal/*) —
# a future crypto/token layer authenticates with this. Generate with
# `openssl rand -hex 32`; never reuse JWT_ACCESS_SECRET here.
INTERNAL_API_KEY=change-me-internal-api-key-min-24-chars
